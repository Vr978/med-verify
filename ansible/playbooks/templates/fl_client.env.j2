# ─────────────────────────────────────────────────────────────────────────────
# MedVerify FL Client — Environment Template
# Rendered by Ansible onto each hospital node at {{ app_dir }}/.env
# Secrets flow in via Ansible Vault or extra-vars — never hardcoded here.
# ─────────────────────────────────────────────────────────────────────────────

# Node identity
NODE_ROLE={{ node_role }}
NODE_ID={{ node_id }}

# FL microservice binding
FL_BACKEND_HOST=0.0.0.0
FL_BACKEND_PORT={{ client_port }}

# Upstream service addresses (GKE LoadBalancer IPs)
BACKEND_API_URL={{ blockchain_api_url }}
FL_AGGREGATOR_BASE={{ fl_backend_aggregator_url }}/fl

# Delegate private key (injected from Ansible Vault — never stored in plaintext)
PRIVATE_KEY_{{ node_id | upper }}={{ delegate_private_key | default('') }}

# Dataset cache
DATASET_CACHE_DIR={{ app_dir }}/dataset_cache

# Logging
LOG_LEVEL=INFO
LOG_FILE=true
LOG_DIR={{ log_dir }}
