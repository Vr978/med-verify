# MongoDB Configuration
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=medverify-authdb

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_AUD=integrity-fl
JWT_ISS=integrity-fl
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7

# Session Configuration
# Maximum number of active sessions per user (set to 1 for single session, 5 for multiple devices, etc.)
MAX_ACTIVE_SESSIONS=5

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable/disable console logging (true/false)
LOG_CONSOLE=true

# Enable/disable file logging (true/false)
LOG_FILE=true

# Log directory path (relative to backend folder or absolute path)
LOG_DIR=logs

# Log file sizes and rotation
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Security log settings
SECURITY_LOG_LEVEL=INFO
SECURITY_LOG_BACKUP_COUNT=10

# Performance log settings
PERFORMANCE_LOG_LEVEL=DEBUG
PERFORMANCE_LOG_BACKUP_COUNT=3

# Error log settings
ERROR_LOG_LEVEL=WARNING
ERROR_LOG_BACKUP_COUNT=10

# Enable/disable colored console output (true/false)
LOG_COLORS=true
